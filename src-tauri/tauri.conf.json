{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BiscuitCode",
  "identifier": "io.github.Coreyalanschmidt-creator.biscuitcode",
  "version": "1.0.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BiscuitCode",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "capabilities": ["core", "fs", "shell", "http", "updater"]
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Coreyalanschmidt-creator/biscuitcode/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhERDhDMkQxODMwRTExMEUKUldRT0VRNkQwY0xZalJUakRMdE8vZjlKOUpuZnJVYkltWjUrK1FKRCtpMjhKdmUrUytuMFh6REoK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "fonts/*": "fonts/"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ],
        "recommends": [
          "gnome-keyring",
          "ollama"
        ],
        "section": "devel",
        "priority": "optional"
      }
    }
  }
}
